# ─── Telnyx ─────────────────────────────────────────────────────────────────
# Clé API V2 (Telnyx Mission Control > API Keys)
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la "Credential Connection" (SIP Connection de type WebRTC)
# Telnyx > Voice > SIP Connections (Credentials)  -> sert à faire sonner le softphone
TELNYX_CONNECTION_ID=0000000000000000000

# ID de la "Call Control Application" (pour piloter le routage entrant/voicemail)
# Telnyx > Voice > Call Control > Applications
TELNYX_CALL_CONTROL_APP_ID=0000000000000000000

# Numéro pro acheté chez Telnyx, au format E.164 (présenté en sortant)
TELNYX_FROM_NUMBER=+33000000000

# Secret de vérification des webhooks (clé publique Telnyx) — à renseigner pour la prod
TELNYX_PUBLIC_KEY=

# ─── API ────────────────────────────────────────────────────────────────────
API_PORT=3001
# URL publique de l'API (Telnyx doit pouvoir l'atteindre pour les webhooks ; utiliser ngrok en local)
PUBLIC_API_URL=https://votre-tunnel.ngrok.io

# ─── Web ────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
