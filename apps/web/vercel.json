{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/play/file/:name",
      "destination": "https://padel-exp-rience-production.up.railway.app/play/file/:name"
    },
    {
      "source": "/play/audio",
      "destination": "https://padel-exp-rience-production.up.railway.app/play/audio"
    },
    {
      "source": "/play",
      "destination": "https://padel-exp-rience-production.up.railway.app/play"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}